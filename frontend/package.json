{
  "name": "indrabet-staff-permission-frontend",
  "version": "1.0.0",
  "description": "Frontend untuk Indrabet Staff Permission System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
